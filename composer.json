{
	"name": "detain/myadmin-gluster-backups",
	"type": "myadmin-plugin",
	"description": "Gluster handling plugin for MyAdmin",
	"keywords": [
		"gluster",
		"backups",
		"myadmin",
		"plugin",
		"administration"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev"
	},
	"require": {
		"php": ">=5.0.0",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0@stable",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminGluster\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminGluster\\Tests\\": "tests/"
		}
	}
}
